# ── LLM Provider ─────────────────────────────────────────────────────────────
# Default: mistral (free tier, no card required)
# Switch at any time via env var or --llm CLI flag

LLM_PROVIDER=mistral          # free default
# LLM_PROVIDER=anthropic      # Claude — best thesis/DD quality (paid)
# LLM_PROVIDER=openai         # GPT-4o (paid)

# Get a free Mistral key at: https://console.mistral.ai/
MISTRAL_API_KEY=

# Paid providers — only needed when switching
# ANTHROPIC_API_KEY=sk-ant-...    # install first: uv add --group anthropic anthropic
# OPENAI_API_KEY=sk-...           # install first: uv add --group openai openai

# ── Data Providers (all optional — free fallbacks always active) ──────────────
# Without these, the tool uses yfinance + SEC EDGAR + EU registries + web search

# Bloomberg (institutional)
# BLOOMBERG_API_KEY=

# Capital IQ
# CAPITALIQ_USERNAME=
# CAPITALIQ_PASSWORD=

# Refinitiv
# REFINITIV_APP_KEY=

# Crunchbase (freemium — improves private company revenue estimates)
# Sign up at: https://www.crunchbase.com/api
# CRUNCHBASE_API_KEY=

# Pappers (recommended for French private companies — verified filed accounts)
# ~€30/month for 500 credits. Key at: https://www.pappers.fr/api
# Unlocks real revenue/EBITDA for Sézane, Doctolib, BlaBlaCar, etc.
# PAPPERS_API_KEY=

# Companies House UK (required — anonymous access removed in 2024)
# Free registration at: https://developer.company-information.service.gov.uk/
# COMPANIES_HOUSE_API_KEY=

# KVK Netherlands (required — API key needed)
# Free registration at: https://developers.kvk.nl/
# KVK_API_KEY=
